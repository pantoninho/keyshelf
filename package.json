{
  "name": "keyshelf",
  "version": "4.2.1",
  "description": "Config and secrets management for monorepos",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pantoninho/keyshelf"
  },
  "bin": {
    "keyshelf": "./dist/bin/keyshelf.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/keyshelf.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "age-encryption": "^0.3.0",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.6",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
