{
  "name": "keyshelf",
  "version": "5.1.1",
  "description": "Config and secrets management for monorepos",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/pantoninho/keyshelf",
    "directory": "packages/cli"
  },
  "bin": {
    "keyshelf": "./dist/bin/keyshelf.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./bin": "./dist/bin/keyshelf.js",
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/src/config/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/keyshelf.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1043.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "age-encryption": "^0.3.0",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.6",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.1"
  }
}
