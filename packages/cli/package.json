{
  "name": "keyshelf",
  "version": "6.4.0",
  "description": "A CLI for managing application config and secrets through pluggable adapters.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/pantoninho/keyshelf",
    "directory": "packages/cli"
  },
  "bin": {
    "keyshelf": "./bin/run.js"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && oclif manifest",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:e2e": "vitest run test/e2e",
    "prepack": "npm run build",
    "platforms:build": "tsx scripts/build-platforms.ts",
    "platforms:verify": "vitest run test/platforms",
    "verdaccio": "tsx scripts/verdaccio-verify.ts"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.2.0",
    "@oclif/core": "^4.0.0",
    "string-width": "^5.1.2",
    "yaml": "^2.4.0"
  },
  "optionalDependencies": {
    "@keyshelf/sops-darwin-arm64": "3.13.1",
    "@keyshelf/sops-darwin-x64": "3.13.1",
    "@keyshelf/sops-linux-arm64": "3.13.1",
    "@keyshelf/sops-linux-x64": "3.13.1",
    "@keyshelf/sops-win32-x64": "3.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oclif": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "verdaccio": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "oclif": {
    "bin": "keyshelf",
    "dirname": "keyshelf",
    "commands": "./dist/commands"
  }
}
