{
  "name": "@keyshelf/migrate",
  "version": "0.1.0",
  "description": "Migrate keyshelf v4 YAML projects to keyshelf.config.ts",
  "type": "module",
  "bin": {
    "keyshelf-migrate": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "keyshelf": "file:../cli",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.1"
  }
}
